rorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"195","messages":"196","suppressedMessages":"197","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"198","messages":"199","suppressedMessages":"200","errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"201"},{"filePath":"202","messages":"203","suppressedMessages":"204","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"205","messages":"206","suppressedMessages":"207","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"208","messages":"209","suppressedMessages":"210","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"211","messages":"212","suppressedMessages":"213","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"214","messages":"215","suppressedMessages":"216","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"217","messages":"218","suppressedMessages":"219","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"220","messages":"221","suppressedMessages":"222","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"223","messages":"224","suppressedMessages":"225","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"226","messages":"227","suppressedMessages":"228","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"229","messages":"230","suppressedMessages":"231","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"232","messages":"233","suppressedMessages":"234","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"235","messages":"236","suppressedMessages":"237","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"238"},{"filePath":"239","messages":"240","suppressedMessages":"241","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"242","messages":"243","suppressedMessages":"244","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"245","messages":"246","suppressedMessages":"247","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"248","messages":"249","suppressedMessages":"250","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"251","messages":"252","suppressedMessages":"253","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"254","messages":"255","suppressedMessages":"256","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"257","messages":"258","suppressedMessages":"259","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Source\\NPTFC\\nptfc\\src\\index.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\reportWebVitals.ts",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\App.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\routes\\routes.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\home.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\layout.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\league-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\tigers-fixture-page.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\league-results.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\players.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\fantasy-stats.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-league-table-update.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-tigers-fixture.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-season.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-player.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-team.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-league-fixture-update.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-fixture.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\pages\\admin\\admin-game-stats.tsx",["260"],[],"import { useFormik } from \"formik\";\r\nimport { useNavigate } from \"react-router-dom\";\r\nimport { Season } from \"../../objects/season\";\r\nimport { useEffect, useState } from \"react\";\r\nimport { GetSeasons } from \"../../services/season-service\";\r\nimport { TigersFixture } from \"../../objects/tigers-fixture\";\r\nimport { GetTigersFixtures } from \"../../services/tigers-fixture-service\";\r\nimport { Player } from \"../../objects/player\";\r\nimport { GetPlayers } from \"../../services/player-service\";\r\nimport { GameStat } from \"../../objects/game-stat\";\r\nimport { PostGameStat } from \"../../services/game-stat-service\";\r\nimport TextField from \"../../atoms/textfield/textfield\";\r\nimport * as Yup from \"yup\";\r\n\r\nconst AdminGameStats = ()  =>\r\n{   \r\n    const [seasons, setSeasons] = useState<Season []>();\r\n    const [fixtures, setFixtures] = useState<TigersFixture []>();    \r\n    const [players, setPlayers] = useState<Player []>();\r\n\r\n    useEffect(() => {        \r\n        GetSeasons().then((data) => setSeasons(data));\r\n        GetTigersFixtures().then((data) => {setFixtures(data)});\r\n        GetPlayers().then((data) => setPlayers(data));\r\n    },[])\r\n\r\n\r\n    const navigate = useNavigate();  \r\n    const formik = useFormik({\r\n        initialValues :{ id : 0, player : 0, fixture : 0, goals : 0, assists : 0, gso : 0, apps : 0, playerName: \"\", shots : 0, tackles : 0, season : 6, shotsOnTarget : 0, shotsOffTarget : 0, cleanSheets : 0, saves : 0},\r\n        onSubmit : values => {\r\n            const gameStat : GameStat = {id : values.id, playerId : values.player, fixtureId : values.fixture, goals : values.goals, assists : values.assists, gso : values.gso, apps : 0, playerName: \"\", shots : values.shots, tackles : values.tackles, seasonId : values.season,\r\n                                        shotsOnTarget : values.shotsOnTarget, shotsOffTarget : values.shotsOffTarget, cleanSheets : values.cleanSheets, saves : values.saves}\r\n                                                    \r\n            PostGameStat(gameStat).then(formik.resetForm);\r\n        },\r\n        // validationSchema: (Yup.object({\r\n        //     goals: Yup\r\n        //     .number()\r\n        //     .min(1, \"Enter some goals or 0\")\r\n        //     .required(\"Enter some goals\"),\r\n        //     assists: Yup\r\n        //     .number()\r\n        //     .min(1, \"Enter some assists or 0\")\r\n        //     .required(\"Enter some assists\") ,\r\n        //     shots: Yup\r\n        //     .number()\r\n        //     .min(1, \"Enter some shots or 0\")\r\n        //     .required(\"Enter some shots\")                        \r\n        // }))\r\n    });\r\n\r\n    return(\r\n        <>     \r\n\r\n            {/* <AdminGameStatsEdit players={players}></AdminGameStatsEdit> */}            \r\n            <div>           \r\n                <form onSubmit={formik.handleSubmit}>\r\n                    <div className=\"row\">   \r\n                        <div className=\"col-2\">\r\n                            <label htmlFor=\"season\" className=\"col-form-label\">Season\r\n                                <select id=\"season\" className=\"form-control\" {...formik.getFieldProps(\"season\")}>\r\n                                    <option>Select your option</option>\r\n                                    {seasons?.map(option => (\r\n                                        <option key={option.id} value={option.id}>U{option.ageGroup + \" \" + option.endYear + \" (Div \" + option.division + \")\"}</option>\r\n                                    ))} \r\n                                </select>\r\n                            </label>\r\n                        </div>   \r\n                        <div className=\"col-3\">\r\n                            <label htmlFor=\"fixture\" className=\"col-form-label\">Fixture\r\n                                <select id=\"fixture\" className=\"form-control\" {...formik.getFieldProps(\"fixture\")}>                                     \r\n                                    <option>Select your option</option>\r\n                                    {fixtures?.map(option => (\r\n                                        <option key={option.id} value={option.id}>{new Date(option.date).toLocaleDateString(\"en-UK\") + \" - \" + option.homeTeam + \" vs \" + option.awayTeam}</option>\r\n                                    ))}\r\n                                </select>\r\n                            </label>\r\n                        </div>                                                  \r\n                        <div className=\"col-2\">\r\n                            <label htmlFor=\"player\" className=\"col-form-label\">Player\r\n                                <select id=\"player\" className=\"form-control\" {...formik.getFieldProps(\"player\")}>          \r\n                                    <option>Select your option</option>                           \r\n                                    {players?.map(option => (\r\n                                        <option key={option.id} value={option.id}>{option.firstname + \" \" + option.surname}</option>\r\n                                    ))}\r\n                                </select>\r\n                            </label>\r\n                        </div>                                            \r\n                    </div>\r\n                    <div className=\"row\">\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Goals\" name=\"goals\" formik={formik}/>\r\n                            {/* {formik.errors.goals && formik.touched.goals ? <span>{formik.errors.goals}</span> : null} */}\r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Assists\" name=\"assists\" formik={formik}/>\r\n                            {/* {formik.errors.assists && formik.touched.assists ? <span>{formik.errors.assists}</span> : null} */}\r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"GSO\" name=\"gso\" formik={formik}/>\r\n                            {/* {formik.errors.gso && formik.touched.gso ? <span>{formik.errors.gso}</span> : null} */}\r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Shots\" name=\"shots\" formik={formik}/>\r\n                            {/* {formik.errors.shots && formik.touched.shots ? <span>{formik.errors.shots}</span> : null}  */}\r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Shots On Target\" name=\"shotsOnTarget\" formik={formik}/>                            \r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Shots Off Target\" name=\"shotsOffTarget\" formik={formik}/>                            \r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Tackles\" name=\"tackles\" formik={formik}/>                            \r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Clean Sheets\" name=\"cleanSheets\" formik={formik}/>                            \r\n                        </div>\r\n                        <div className=\"col-2\">\r\n                            <TextField label=\"Saves\" name=\"saves\" formik={formik}/>                            \r\n                        </div>\r\n                    </div> \r\n                   \r\n                    <div className=\"row\">\r\n                        <div className=\"col-2\">\r\n                            <button className=\"btn btn-secondary\" type=\"button\" onClick={()=> navigate('/Admin')}>Back</button>    \r\n                            <button className=\"btn btn-primary\" type=\"submit\">Go</button>    \r\n                        </div>\r\n                    </div> \r\n                </form>            \r\n            </div>\r\n        </>\r\n    );\r\n}\r\n\r\nexport default AdminGameStats;\r\n\r\n\r\n\r\n\r\n// import { useFormik } from \"formik\";\r\n// import { useNavigate } from \"react-router-dom\";\r\n// import { Season } from \"../../objects/season\";\r\n// import { useEffect, useState } from \"react\";\r\n// import { GetSeasons } from \"../../services/season-service\";\r\n// import { TigersFixture } from \"../../objects/tigers-fixture\";\r\n// import { GetTigersFixtures } from \"../../services/tigers-fixture-service\";\r\n// import { Player } from \"../../objects/player\";\r\n// import { GetPlayers } from \"../../services/player-service\";\r\n// import { GameStat } from \"../../objects/game-stat\";\r\n// import { PostGameStat } from \"../../services/game-stat-service\";\r\n// import TextField from \"../../atoms/textfield/textfield\";\r\n// import AdminGameStat from \"../../components/admin/admin-game-stat\";\r\n\r\n// const AdminGameStats = ()  =>\r\n// {   \r\n//     const [seasons, setSeasons] = useState<Season []>();\r\n//     const [fixtures, setFixtures] = useState<TigersFixture []>();    \r\n//     const [players, setPlayers] = useState<Player []>();\r\n\r\n//     useEffect(() => {        \r\n//         GetSeasons().then((data) => setSeasons(data));\r\n//         GetTigersFixtures().then((data) => {setFixtures(data)});\r\n//         GetPlayers().then((data) => setPlayers(data));\r\n//     },[])\r\n\r\n\r\n//     const navigate = useNavigate();  \r\n//     const formik = useFormik({\r\n//         initialValues :{ id : 0, player : 0, fixture : 0, goals : 0, assists : 0, gso : 0, apps : 0, playerName: \"\", shots : 0, tackles : 0, season : 0},\r\n//         onSubmit : values => {\r\n//             const gameStat : GameStat = {id : values.id, playerId : values.player, fixtureId : values.fixture, goals : values.goals, assists : values.assists, gso : values.gso, apps : 0, playerName: \"\", shots : values.shots, tackles : values.tackles, seasonId : values.season}\r\n//             PostGameStat(gameStat).then(formik.resetForm);\r\n//         }\r\n//     });\r\n\r\n//     return(\r\n//         <>       \r\n//             <div>           \r\n//                 <form onSubmit={formik.handleSubmit}>\r\n//                     <div className=\"row\">   \r\n//                         <div className=\"col-2\">\r\n//                             <label htmlFor=\"season\" className=\"col-form-label\">Season\r\n//                                 <select id=\"season\" className=\"form-control\" {...formik.getFieldProps(\"season\")}>\r\n//                                     <option>Select your option</option>\r\n//                                     {seasons?.map(option => (\r\n//                                         <option key={option.id} value={option.id}>U{option.ageGroup + \" \" + option.endYear + \" (Div \" + option.division + \")\"}</option>\r\n//                                     ))} \r\n//                                 </select>\r\n//                             </label>\r\n//                         </div>   \r\n//                         <div className=\"col-3\">\r\n//                             <label htmlFor=\"fixture\" className=\"col-form-label\">Fixture\r\n//                                 <select id=\"fixture\" className=\"form-control\" {...formik.getFieldProps(\"fixture\")}>                                     \r\n//                                     <option>Select your option</option>\r\n//                                     {fixtures?.map(option => (\r\n//                                         <option key={option.id} value={option.id}>{new Date(option.date).toLocaleDateString(\"en-UK\") + \" - \" + option.homeTeam + \" vs \" + option.awayTeam}</option>\r\n//                                     ))}\r\n//                                 </select>\r\n//                             </label>\r\n//                         </div>                                                  \r\n//                         <div className=\"col-2\">\r\n//                             <label htmlFor=\"player\" className=\"col-form-label\">Player\r\n//                                 <select id=\"player\" className=\"form-control\" {...formik.getFieldProps(\"player\")}>          \r\n//                                     <option>Select your option</option>                           \r\n//                                     {players?.map(option => (\r\n//                                         <option key={option.id} value={option.id}>{option.firstname + \" \" + option.surname}</option>\r\n//                                     ))}\r\n//                                 </select>\r\n//                             </label>\r\n//                         </div>                                            \r\n//                     </div>\r\n//                     <div className=\"row\">\r\n//                         <div className=\"col-2\">\r\n//                             <TextField label=\"Goals\" name=\"goals\" value=\"0\" formik={formik}/>\r\n//                         </div>\r\n//                         <div className=\"col-2\">\r\n//                             <TextField label=\"Assists\" name=\"assists\" value=\"0\" formik={formik}/>\r\n//                         </div>\r\n//                         <div className=\"col-2\">\r\n//                             <TextField label=\"GSO\" name=\"gso\" value=\"0\" formik={formik}/>\r\n//                         </div>\r\n//                         <div className=\"col-2\">\r\n//                             <TextField label=\"Shots\" name=\"shots\" value=\"0\" formik={formik}/>\r\n//                         </div>\r\n//                         <div className=\"col-2\">\r\n//                             <TextField label=\"Tackles\" name=\"tackles\" value=\"0\" formik={formik}/>\r\n//                         </div>\r\n//                     </div> \r\n                   \r\n//                     <div className=\"row\">\r\n//                         <div className=\"col-2\">\r\n//                             <button className=\"btn btn-secondary\" onClick={()=> navigate('/Admin')}>Back</button>    \r\n//                             <button className=\"btn btn-primary\" type=\"submit\">Go</button>    \r\n//                         </div>\r\n//                     </div> \r\n//                 </form>            \r\n//             </div>\r\n//         </>\r\n//     );\r\n// }\r\n\r\n// export default AdminGameStats;","C:\\Source\\NPTFC\\nptfc\\src\\pages\\season\\season-view.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\tigers-fixture-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\season-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\game-stat-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\league-table-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\fantasy-stat-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\player-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\fixture-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\player-card.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\season-card.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\game-stats\\game-stat-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header.tsx",["261","262","263"],[],"import { AppBar, Avatar, Box,  Container, IconButton, ThemeProvider, Toolbar, createTheme } from '@mui/material';\r\nimport './header.css';\r\nimport { green, lightBlue } from '@mui/material/colors';\r\nimport HeaderMenuCollapsed from './header-menu-collapsed';\r\nimport HeaderMenuLogo from './header-menu-logo';\r\nimport HeaderMenuNav from './header-menu-nav';\r\n\r\nconst theme = createTheme({\r\n    palette: {\r\n      primary: green,\r\n      secondary: lightBlue,\r\n    },\r\n  });\r\n\r\nconst Header = () => { \r\n    \r\n    return(        \r\n        <ThemeProvider theme={theme}>\r\n            <AppBar position=\"static\">\r\n                <Container>\r\n                <Toolbar >  \r\n                    <HeaderMenuCollapsed/>\r\n                    <HeaderMenuLogo/>\r\n                    <HeaderMenuNav/>                  \r\n                </Toolbar>\r\n                </Container>\r\n        </AppBar>    \r\n      </ThemeProvider>\r\n    );\r\n}\r\nexport default Header;","C:\\Source\\NPTFC\\nptfc\\src\\components\\league-table\\league-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\teams-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\single-tigers-fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\tigers-fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-grid.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fantasy\\fantasy-stat-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fantasy\\fantasy-scoring.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\textfield\\textfield.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\button\\button-atom.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\objects\\enums\\enums.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\player-stats-table-row.tsx",["264"],[],"import { useEffect, useState } from \"react\";\r\nimport { Player } from \"../../objects/player\";\r\nimport { GameStat } from \"../../objects/game-stat\";\r\nimport { GetTotalAssists, GetTotalGSO, GetTotalGames, GetTotalGoals, GetTotalShots, GetTotalTackles } from \"../../utils/game-stats-util\";\r\nimport { Season } from \"../../objects/season\";\r\nimport { GetSeasonGameStatsForPlayer } from \"../../services/game-stat-service\";\r\n\r\ninterface playerStatsProps{\r\n    player : Player,\r\n    season : Season\r\n}\r\n\r\nconst PlayerStatsTableRow = (playerStatsProps : playerStatsProps) => {     \r\n\r\n    const [gameStats, setGameStats] = useState<GameStat[] | null>(null);\r\n    const [totalGames, setTotalGame] = useState(0);\r\n    const [totalGoals, setGoals] = useState(0);\r\n    const [totalAssist, setAssistGoals] = useState(0);\r\n    const [totalGSOs, setGSOs] = useState(0);    \r\n    const [totalShots, setShots] = useState(0);\r\n\r\n    useEffect(() =>\r\n    {\r\n        GetSeasonGameStatsForPlayer(playerStatsProps.season.id, playerStatsProps.player.id).then(gameStats => setGameStats(gameStats));\r\n    })\r\n    \r\n    useEffect(() => {\r\n        if (gameStats != null)\r\n        {\r\n            setTotalGame(GetTotalGames({gameStats : gameStats}));\r\n            setGoals(GetTotalGoals({gameStats : gameStats}));\r\n            setAssistGoals(GetTotalAssists({gameStats : gameStats}));\r\n            setGSOs(GetTotalGSO({gameStats : gameStats}));            \r\n            setShots(GetTotalShots({gameStats : gameStats}));\r\n        }\r\n    }, [gameStats]);    \r\n\r\n    return(             \r\n            <tr>\r\n                <td>U{playerStatsProps.season.ageGroup}'s</td>\r\n                <td>{playerStatsProps.season.division}</td>\r\n                <td>{totalGames}</td>\r\n                <td>{totalGoals}</td>\r\n                <td>{totalAssist}</td>\r\n                <td>{totalGSOs}</td>                            \r\n                <td>{totalShots}</td>                \r\n            </tr>                        \r\n    )\r\n}\r\nexport default PlayerStatsTableRow;","C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-nav.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-logo.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\league-table\\league-table-row.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-collapsed.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\utils\\game-stats-util.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\tigers-fixture-row.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-row.tsx",[],[],{"ruleId":"265","severity":1,"message":"266","line":13,"column":13,"nodeType":"267","messageId":"268","endLine":13,"endColumn":16},{"ruleId":"265","severity":1,"message":"269","line":1,"column":18,"nodeType":"267","messageId":"268","endLine":1,"endColumn":24},{"ruleId":"265","severity":1,"message":"270","line":1,"column":26,"nodeType":"267","messageId":"268","endLine":1,"endColumn":29},{"ruleId":"265","severity":1,"message":"271","line":1,"column":43,"nodeType":"267","messageId":"268","endLine":1,"endColumn":53},{"ruleId":"265","severity":1,"message":"272","line":4,"column":85,"nodeType":"267","messageId":"268","endLine":4,"endColumn":100},"@typescript-eslint/no-unused-vars","'Yup' is defined but never used.","Identifier","unusedVar","'Avatar' is defined but never used.","'Box' is defined but never used.","'IconButton' is defined but never used.","'GetTotalTackles' is defined but never used."]