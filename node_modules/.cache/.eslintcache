asy-stat-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\fixture-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\player-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\services\\teams-service.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\player-card.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\season-card.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fantasy\\fantasy-scoring.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\league-table\\league-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\game-stats\\game-stat-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fantasy\\fantasy-stat-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\single-tigers-fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\tigers-fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-table.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header.tsx",["261","262","263"],[],"import { AppBar, Avatar, Box,  Container, IconButton, ThemeProvider, Toolbar, createTheme } from '@mui/material';\r\nimport './header.css';\r\nimport { green, lightBlue } from '@mui/material/colors';\r\nimport HeaderMenuCollapsed from './header-menu-collapsed';\r\nimport HeaderMenuLogo from './header-menu-logo';\r\nimport HeaderMenuNav from './header-menu-nav';\r\n\r\nconst theme = createTheme({\r\n    palette: {\r\n      primary: green,\r\n      secondary: lightBlue,\r\n    },\r\n  });\r\n\r\nconst Header = () => { \r\n    \r\n    return(        \r\n        <ThemeProvider theme={theme}>\r\n            <AppBar position=\"static\">\r\n                <Container>\r\n                <Toolbar >  \r\n                    <HeaderMenuCollapsed/>\r\n                    <HeaderMenuLogo/>\r\n                    <HeaderMenuNav/>                  \r\n                </Toolbar>\r\n                </Container>\r\n        </AppBar>    \r\n      </ThemeProvider>\r\n    );\r\n}\r\nexport default Header;","C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-grid.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\button\\button-atom.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\textfield\\textfield.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\objects\\enums\\enums.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\atoms\\card\\player-stats-table-row.tsx",["264"],[],"import { useEffect, useState } from \"react\";\r\nimport { Player } from \"../../objects/player\";\r\nimport { GameStat } from \"../../objects/game-stat\";\r\nimport { GetTotalAssists, GetTotalGSO, GetTotalGames, GetTotalGoals, GetTotalShots, GetTotalTackles } from \"../../utils/game-stats-util\";\r\nimport { Season } from \"../../objects/season\";\r\nimport { GetSeasonGameStatsForPlayer } from \"../../services/game-stat-service\";\r\n\r\ninterface playerStatsProps{\r\n    player : Player,\r\n    season : Season\r\n}\r\n\r\nconst PlayerStatsTableRow = (playerStatsProps : playerStatsProps) => {     \r\n\r\n    const [gameStats, setGameStats] = useState<GameStat[] | null>(null);\r\n    const [totalGames, setTotalGame] = useState(0);\r\n    const [totalGoals, setGoals] = useState(0);\r\n    const [totalAssist, setAssistGoals] = useState(0);\r\n    const [totalGSOs, setGSOs] = useState(0);    \r\n    const [totalShots, setShots] = useState(0);\r\n\r\n    useEffect(() =>\r\n    {\r\n        GetSeasonGameStatsForPlayer(playerStatsProps.season.id, playerStatsProps.player.id).then(gameStats => setGameStats(gameStats));\r\n    })\r\n    \r\n    useEffect(() => {\r\n        if (gameStats != null)\r\n        {\r\n            setTotalGame(GetTotalGames({gameStats : gameStats}));\r\n            setGoals(GetTotalGoals({gameStats : gameStats}));\r\n            setAssistGoals(GetTotalAssists({gameStats : gameStats}));\r\n            setGSOs(GetTotalGSO({gameStats : gameStats}));            \r\n            setShots(GetTotalShots({gameStats : gameStats}));\r\n        }\r\n    }, [gameStats]);    \r\n\r\n    return(             \r\n            <tr>\r\n                <td>U{playerStatsProps.season.ageGroup}'s</td>\r\n                <td>{playerStatsProps.season.division}</td>\r\n                <td>{totalGames}</td>\r\n                <td>{totalGoals}</td>\r\n                <td>{totalAssist}</td>\r\n                <td>{totalGSOs}</td>                            \r\n                <td>{totalShots}</td>                \r\n            </tr>                        \r\n    )\r\n}\r\nexport default PlayerStatsTableRow;","C:\\Source\\NPTFC\\nptfc\\src\\components\\tigers-fixture\\tigers-fixture-row.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\league-table\\league-table-row.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\fixtures\\fixture-row.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-collapsed.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\utils\\game-stats-util.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-nav.tsx",[],[],"C:\\Source\\NPTFC\\nptfc\\src\\components\\header\\header-menu-logo.tsx",[],[],{"ruleId":"265","severity":1,"message":"266","line":13,"column":13,"nodeType":"267","messageId":"268","endLine":13,"endColumn":16},{"ruleId":"265","severity":1,"message":"269","line":1,"column":18,"nodeType":"267","messageId":"268","endLine":1,"endColumn":24},{"ruleId":"265","severity":1,"message":"270","line":1,"column":26,"nodeType":"267","messageId":"268","endLine":1,"endColumn":29},{"ruleId":"265","severity":1,"message":"271","line":1,"column":43,"nodeType":"267","messageId":"268","endLine":1,"endColumn":53},{"ruleId":"265","severity":1,"message":"272","line":4,"column":85,"nodeType":"267","messageId":"268","endLine":4,"endColumn":100},"@typescript-eslint/no-unused-vars","'Yup' is defined but never used.","Identifier","unusedVar","'Avatar' is defined but never used.","'Box' is defined but never used.","'IconButton' is defined but never used.","'GetTotalTackles'